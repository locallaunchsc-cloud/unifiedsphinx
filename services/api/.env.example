# UnifiedSphinx API — environment variables
# Copy this to .env (or export inline) before running the server or scripts.

# ----- x402 / payments --------------------------------------------------------
# Wallet that receives USDC payments. Receive-only — no private key needed here.
X402_PAY_TO=0xaFa55F80461eB78d02E66dcf729F01f995CCa208

# Network: base-sepolia (testnet) or base (mainnet).
X402_NETWORK=base-sepolia

# Per-call price, USD-denominated (USDC).
X402_PRICE=$0.0005

# ----- Coinbase CDP credentials ----------------------------------------------
# Required to use CDP's facilitator and get listed on Agentic.Market.
# Without these, the server falls back to the public x402.org facilitator,
# which works for testing but does NOT trigger Agentic.Market indexing.
#
# Get these at https://portal.cdp.coinbase.com/
# Key ID is non-secret. Secret is sensitive — never commit it.
CDP_API_KEY_ID=80d57fd8-9b85-402b-a6c1-4b9141efa010
CDP_API_KEY_SECRET=

# ----- Listing trigger script (scripts/trigger-listing.js) -------------------
# Optional: a private key for the buyer wallet that pays for the test call.
# If unset, the script generates a fresh one and prints it so you can fund it
# with Base Sepolia USDC at https://faucet.circle.com.
# Format: 0x-prefixed 32-byte hex.
BUYER_PRIVATE_KEY=

# Where the running API is reachable from the script.
API_BASE_URL=http://localhost:8000
